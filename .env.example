# Copy this file to ".env" and adjust values. The app runs fine with these defaults.

PORT=3000

# Used to sign owner/admin login tokens. CHANGE THIS to a long random string.
JWT_SECRET=change-this-to-a-long-random-string

# Password you (the company owner) use to log into the Admin panel.
# If left blank, the app uses the "admin.password" value from credentials.json.
ADMIN_PASSWORD=admin123

# Default geofence radius (metres) if a restaurant does not set its own.
DEFAULT_RADIUS_METERS=100

# ---------------------------------------------------------------------------
# DATABASE (MongoDB Atlas)
# Leave MONGODB_URI BLANK to store data in a local JSON file (data/db.json) -
# perfect for local testing, no account needed.
#
# To use MongoDB Atlas (free): create a free cluster, add a database user, then
# copy the "Connect > Drivers" connection string here. Replace <password> with
# your database user's password and keep the trailing db name/params.
# Example:
#   MONGODB_URI=mongodb+srv://myuser:mypassword@cluster0.abcde.mongodb.net/?retryWrites=true&w=majority
# ---------------------------------------------------------------------------
MONGODB_URI=
MONGODB_DB=foodorder

CURRENCY=INR

# ---------------------------------------------------------------------------
# PAYMENTS
# Leave the two RAZORPAY_* keys BLANK to run in free "mock" mode (no real money,
# no account needed) — perfect for testing. The order flow works end to end.
#
# To enable real Razorpay UPI checkout, create a Razorpay account, grab your
# TEST keys (Dashboard > Settings > API Keys), and paste them below.
# ---------------------------------------------------------------------------
PAYMENT_PROVIDER=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
